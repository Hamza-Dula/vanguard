{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "XDebug 9003",
			"type": "php",
			"request": "launch",
			"port": 9003,
			"xdebugSettings": {
				"max_data": -1
			}
		},
		{
			"name": "XDebug 9000",
			"type": "php",
			"request": "launch",
			"port": 9000,
			"xdebugSettings": {
				"max_data": -1
			}
		},

		{
			"name": "Launch currently open script",
			"type": "php",
			"request": "launch",
			"program": "${file}",
			"cwd": "${fileDirname}",
			"port": 9000
		}
	]
}








